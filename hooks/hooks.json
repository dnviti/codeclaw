{
  "hooks": {
    "PrePush": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAW_ROOT:-${CLAUDE_PLUGIN_ROOT}}/scripts/quality_gate.py --root . --verify-command \"${VERIFY_COMMAND}\" --json"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Grep|Glob|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAW_ROOT:-${CLAUDE_PLUGIN_ROOT}}/scripts/hooks/pre_tool_offload.py \"$CLAUDE_TOOL_NAME\" \"$CLAUDE_TOOL_INPUT\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAW_ROOT:-${CLAUDE_PLUGIN_ROOT}}/scripts/task_manager.py hook \"$CLAUDE_FILE_PATH\""
          }
        ]
      }
    ]
  }
}
