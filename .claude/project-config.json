{
  "dev_ports": "",
  "start_command": "",
  "predev_command": "",
  "verify_command": "python3 -m pytest --tb=short -q",
  "test_framework": "pytest",
  "test_command": "python3 -m pytest --tb=short -q",
  "test_file_pattern": "test_*.py",
  "ci_runtime_setup": "setup-python@v5 python-version=3.12",
  "tech_detail_layers": "Python scripts, Claude Code plugin skills, MCP server",
  "idea_categories": "",
  "doc_categories": "",
  "project_context": "Claude Code plugin framework providing task, idea, release, docs, setup, update, tests, and help skills",
  "scout_categories": "",
  "package_json_paths": ".claude-plugin/plugin.json",
  "changelog_file": "CHANGELOG.md",
  "tag_prefix": "v",
  "github_repo_url": "https://github.com/dnviti/claude-task-development-framework",
  "release_branch": "develop",
  "show_generated_footer": true,
  "python_command": "python3",
  "quality_gate": {
    "enabled": true,
    "fail_on": [
      "critical",
      "high"
    ],
    "auto_fix": true,
    "max_fix_iterations": 3,
    "skip_tools": [],
    "extra_args": {}
  },
  "memory_consistency": {
    "gc_ttl_days": 30,
    "max_index_size_mb": 500,
    "conflict_strategy": "auto",
    "enable_versioned_reads": false
  },
  "vector_memory": {
    "enabled": false,
    "auto_index": true,
    "embedding_provider": "local",
    "embedding_model": "all-MiniLM-L6-v2",
    "embedding_api_key_env": "",
    "chunk_size": 2000,
    "index_path": ".claude/memory/vectors",
    "batch_size": 64,
    "include_patterns": [],
    "exclude_patterns": [],
    "search_log": {
      "enabled": false,
      "path": ".claude/memory/search_log.jsonl",
      "include_content": false,
      "max_size_mb": 10,
      "retention_days": 30,
      "_privacy_notice": "When enabled, search queries and result metadata are written to disk in plaintext. This may include sensitive data such as code patterns, file paths, and search terms. Logs are created with 0o600 permissions and auto-purged after retention_days."
    }
  },
  "mcp_server": {
    "enabled": false,
    "transport": "stdio",
    "auto_start": true,
    "_comment": "Vector memory MCP is opt-in. Enable via /setup. Requires: pip install \"mcp>=1.0\" \"lancedb>=0.5.0,<1.0\" \"sentence-transformers>=2.7.0,<3.0\""
  },
  "social_announce": {
    "platforms": {
      "bluesky": {
        "enabled": false
      },
      "mastodon": {
        "enabled": false
      },
      "discord": {
        "enabled": false
      },
      "slack": {
        "enabled": false
      }
    },
    "clipboard_platforms": [
      {
        "name": "twitter",
        "enabled": false,
        "max_length": 280,
        "post_url": "https://twitter.com/compose/tweet"
      },
      {
        "name": "linkedin",
        "enabled": false,
        "max_length": 3000,
        "post_url": "https://www.linkedin.com/feed/"
      },
      {
        "name": "reddit",
        "enabled": false,
        "max_length": 10000,
        "post_url": ""
      },
      {
        "name": "hackernews",
        "enabled": false,
        "max_length": 2000,
        "post_url": "https://news.ycombinator.com/submit"
      }
    ]
  },
  "ollama": {
    "enabled": false,
    "model": "qwen3.5:latest",
    "offloading_level": 5
  }
