{
  "enabled": false,
  "model": "",
  "api_base": "http://localhost:11434",
  "hardware": {
    "ram_gb": 0,
    "vram_gb": 0,
    "gpu_vendor": "none",
    "cpu_cores": 0
  },
  "offloading": {
    "level": 5,
    "auto_route": true,
    "offloadable_tasks": [
      "generate-boilerplate",
      "format-code",
      "write-docstrings",
      "simple-refactor",
      "generate-tests-simple",
      "explain-code",
      "variable-naming"
    ],
    "tool_calls": {
      "enabled": false,
      "include_tools": ["Bash", "Read", "Grep", "Glob", "Edit", "Write"],
      "exclude_patterns": [
        "git push",
        "git reset",
        "rm -rf",
        "sudo",
        "chmod",
        "chown"
      ]
    },
    "max_tokens": 2048,
    "temperature": 0.1
  },
  "installation": {
    "auto_start": false,
    "pull_on_setup": true
  }
}
